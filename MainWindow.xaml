<Window x:Class="Volt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Volt"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Width="605" SizeToContent="Height" WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize">
    <Window.Background>
        <ImageBrush ImageSource="/VoltIcon.png" Opacity="0.5" Stretch="Fill"/>
    </Window.Background>
    <Window.Resources>
        <SolidColorBrush x:Key="ClockRowBackground" Color="#FF1E1E1E" />
        <SolidColorBrush x:Key="ClockAltRowBackground" Color="#FF262626" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid x:Name="Grid_Background_FanCurve" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Hidden" Background="Transparent" />
        <!-- Treiber Version Anzeige Statusleiste -->
        <StackPanel x:Name="panel_driverV" Grid.ColumnSpan="2" Background="Black" Height="21" Width="Auto" VerticalAlignment="Top" MouseDown="panel_driverV_MouseDown">
            <StatusBar x:Name="topStatusBar" Width="auto" Margin="0,0,0,2" Height="auto" >
                <Image x:Name="img_driverIcon" Source="/VoltIcon.png" Width="16" Height="16" />
                <Label x:Name="lb_driverV" Content="Driver Version" Width="auto" Padding="0,0,0,0" VerticalContentAlignment="Center" Height="15"/>

            </StatusBar>
        </StackPanel>

        <!--Manuelle Lüftersteuerung Slider-->
        <Grid x:Name="panel_fanControl" Grid.Row="1" Grid.Column="1" Height="89" Margin="0,6,10,0" VerticalAlignment="Top" HorizontalAlignment="Right" Width="92">
            <Slider x:Name="slider_fanSpeed" Minimum="0" Maximum="100" HorizontalAlignment="Left" Margin="-16,27,0,0" VerticalAlignment="Top" Width="58" RenderTransformOrigin="0.5,0.5" ValueChanged="slider_fanSpeed_ValueChanged">
                <Slider.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Slider.RenderTransform>
            </Slider>
            <TextBox x:Name="tb_fanSpeed" HorizontalAlignment="Left" Margin="26,24,0,45" TextWrapping="NoWrap" Text="100" Width="25" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="#FF464646" BorderThickness="1,1,1,1" Background="White"/>
            <CheckBox x:Name="cb_autoFanSpeed" Content="Auto" HorizontalAlignment="Center" Width="50" Margin="10,50,0,0" VerticalAlignment="Top" Unchecked="cb_autoFanSpeed_Unchecked" Checked="cb_autoFanSpeed_Checked" Foreground="White"/>
            <Label Content="Fan Control" HorizontalAlignment="Left" Margin="26,4,0,0" VerticalAlignment="Top" Height="16" Padding="0,0,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Stretch" Foreground="White"/>
            <StackPanel/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,70,0,0" VerticalAlignment="Top">
                <Button x:Name="btn_FanCurve" Content="FanCurve" FontSize="9" Height="15" Click="btn_FanCurve_Click" Margin="0,0,4,0"/>
                <Button x:Name="btn_FanCurveReset" Content="Reset" FontSize="9" Height="15" Click="btn_FanCurveReset_Click"/>
            </StackPanel>
        </Grid>

        <!--Core und Memory Clock Labels-->
        <Grid x:Name="grid_clocks" Grid.Row="1" Grid.Column="0"
              Background="#FF111111"
              Margin="4,5,4,5"
              HorizontalAlignment="Stretch" Opacity="0.8">
            <Grid.Resources>
                <Style TargetType="Label">
                    <Setter Property="Foreground" Value="White" />
                </Style>
                <Style TargetType="Button">
                    <Setter Property="Foreground" Value="White" />
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid x:Name="dataGrid_clocks"
                      CanUserSortColumns="False"
                      Grid.Row="0"
                      Margin="1"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      ColumnHeaderHeight="25" 
                      GridLinesVisibility="All"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      RowBackground="{StaticResource ClockRowBackground}"
                      AlternatingRowBackground="{StaticResource ClockAltRowBackground}"
                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Stretch"
                      Height="Auto" Foreground="White">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="#FF3A3A3A" />
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Background" Value="#FF1A1A1A" />
                        <Setter Property="BorderBrush" Value="#FF3A3A3A" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Information" Binding="{Binding Name}" Width="Auto" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="Auto">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Avg" Binding="{Binding Avg}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
            <Button Content="Reset" Grid.Row="1" HorizontalAlignment="Right" Margin="2" VerticalAlignment="Bottom" Height="20" RenderTransformOrigin="0.5,0.5" Click="Button_Click" Foreground="Black">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
            <!-- Label mit vergangener Zeit -->
            <Label x:Name="lbl_elapsedTime" Content="Elapsed Time: 00:00:00" Grid.Row="1" HorizontalAlignment="Left" Margin="2" VerticalAlignment="Bottom"/>
        </Grid>



        <!--GPU Core Clock OC-->
        <Button x:Name="btn_close_application" Grid.Row="0" Grid.Column="1" Content="X" HorizontalAlignment="Right" Margin="0,3,11,0" VerticalAlignment="Top" Click="CloseApplication" Width="18" Height="18" BorderThickness="0,0,0,0" Background="White" FontWeight="Bold"/>
        <Button x:Name="btn_maximize_window" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Margin="0,3,31,0" VerticalAlignment="Top" Width="18" Height="18" BorderThickness="0,0,0,0" Visibility="Hidden">
            <Button.Background>
                <RadialGradientBrush>
                    <GradientStop Color="Black" Offset="0.853"/>
                    <GradientStop Color="White" Offset="0"/>
                </RadialGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="btn_minimize_window" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" Margin="0,3,34,0" VerticalAlignment="Top" Click="Minimize_Window" Width="18" Height="18" BorderThickness="0,0,0,0">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.871"/>
                    <GradientStop Color="White" Offset="0.785"/>
                    <GradientStop Color="#FFF1EDED" Offset="0.867"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>





    </Grid>


</Window>
