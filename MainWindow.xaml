<Window x:Class="Volt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Volt"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="201" Width="290"  WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize">
    <Window.Background>
        <SolidColorBrush Opacity="0.5" Color="Gray"/>
    </Window.Background>
    <Grid>
        <!-- Treiber Version Anzeige Statusleiste -->
        <StackPanel x:Name="panel_driverV" Background="Black" Height="21" Width="Auto" VerticalAlignment="Top" MouseDown="panel_driverV_MouseDown">
            <StatusBar x:Name="topStatusBar" Width="auto" Margin="2,2,2,2" Height="auto" >
                <Label x:Name="lb_driverV" Content="Driver Version" Width="115" Padding="0,0,0,0" VerticalContentAlignment="Center" Height="15"/>

            </StatusBar>
        </StackPanel>

        <!--Manuelle Lüftersteuerung Slider-->
        <Grid x:Name="panel_fanControl" Height="89" Margin="189,31,0,0" VerticalAlignment="Top" Background="#FF9A9A9A" HorizontalAlignment="Left" Width="92">
            <Slider x:Name="slider_fanSpeed" Minimum="0" Maximum="100" HorizontalAlignment="Left" Margin="-16,27,0,0" VerticalAlignment="Top" Width="58" RenderTransformOrigin="0.5,0.5" ValueChanged="slider_fanSpeed_ValueChanged">
                <Slider.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Slider.RenderTransform>
            </Slider>
            <TextBox x:Name="tb_fanSpeed" HorizontalAlignment="Left" Margin="26,24,0,45" TextWrapping="NoWrap" Text="100" Width="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderBrush="#FF464646" BorderThickness="1,1,1,1" Background="White"/>
            <CheckBox x:Name="cb_autoFanSpeed" Content="Auto" HorizontalAlignment="Center" Margin="0,50,0,0" VerticalAlignment="Top" Unchecked="cb_autoFanSpeed_Unchecked" Checked="cb_autoFanSpeed_Checked"/>
            <Label Content="Fan Control" HorizontalAlignment="Left" Margin="26,4,0,0" VerticalAlignment="Top" Height="16" Padding="0,0,0,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Stretch"/>
            <StackPanel/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,70,0,0" VerticalAlignment="Top">
                <Button x:Name="btn_FanCurve" Content="FanCurve" FontSize="9" Height="15" Click="btn_FanCurve_Click" Margin="0,0,4,0"/>
                <Button x:Name="btn_FanCurveReset" Content="Reset" FontSize="9" Height="15" Click="btn_FanCurveReset_Click"/>
            </StackPanel>
        </Grid>

        <!--Core und Memory Clock Labels-->
        <Grid x:Name="grid_clocks" Background="White" Width="174" Margin="10,27,0,5" HorizontalAlignment="Left">
            <DataGrid x:Name="dataGrid_clocks" Margin="2,2,2,2" HeadersVisibility="None" GridLinesVisibility="None" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Binding="{Binding Value}" Width="Auto" />
                </DataGrid.Columns>
            </DataGrid>
            <!--   --><!--GPU Temperatur--><!--
            <Grid x:Name="gpu_core_temp" Background="LightGoldenrodYellow" VerticalAlignment="Top" Height="21" Margin="2,2,2,1">
                <Label x:Name="lb_gpu_temp" Content="GPU Temperature:" Padding="0,0,0,0" Height="15" Margin="5,2,26,2" HorizontalAlignment="Left" HorizontalContentAlignment="Left" />
                <Label x:Name="lb_gpu_temp_sensor" Content="155°C"  Margin="98,3,5,3" FontWeight="Bold" Padding="0,0,0,0" FontSize="11" Height="14" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Grid x:Name="grid_coreClk" Background="LightCyan" Height="20" Margin="2,26,2,1" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="54*"/>
                    <ColumnDefinition Width="31*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_gpu_coreclk" Content="Core Clock:" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Height="15" Width="80" Margin="5,0,0,0"/>
                <Label x:Name="lb_gpu_frequency" Content="core mhz" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Height="15" VerticalContentAlignment="Center" Width="70" HorizontalContentAlignment="Right" Grid.ColumnSpan="2"/>
            </Grid>
            <Grid x:Name="grid_memClk" Background="LightPink" Margin="2,50,2,0" Height="20" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="113*"/>
                    <ColumnDefinition Width="57*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_gpu_memclk" Content="Memory Clock:" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" Width="80" Padding="0,0,0,0" Height="15"/>
                <Label x:Name="lb_mem_frequency" Content="mem mhz" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Width="70" Height="15" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
            </Grid>
            <Grid x:Name="grid_power_curr"  Margin="2,74,2,0" Height="20" VerticalAlignment="Top" Background="#FFEAEC09">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="113*"/>
                    <ColumnDefinition Width="57*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_voltage_curr" Content="Curr. Voltage:" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" Width="80" Padding="0,0,0,0" Height="15"/>
                <Label x:Name="lb_voltage_curr_voltage" Content="V" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Width="70" Height="15" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
            </Grid>
            <Grid x:Name="grid_power_curr_Kopieren"  Margin="2,99,2,0" Height="20" VerticalAlignment="Top" Background="#FFEAEC09">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="113*"/>
                    <ColumnDefinition Width="57*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_power_curr" Content="Curr. Power:" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" Width="80" Padding="0,0,0,0" Height="15"/>
                <Label x:Name="lb_power_curr_power" Content="W" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Width="70" Height="15" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
            </Grid>
            <Grid x:Name="grid_load_curr"  Margin="2,124,2,0" Height="20" VerticalAlignment="Top" Background="#FFEAEC09">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="113*"/>
                    <ColumnDefinition Width="57*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_load_curr" Content="Curr. load:" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" Width="80" Padding="0,0,0,0" Height="15"/>
                <Label x:Name="lb_load_curr_load" Content="W" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Width="70" Height="15" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
            </Grid>
            <Grid x:Name="grid_memory_curr"  Margin="2,147,2,0" Height="20" VerticalAlignment="Top" Background="#FF09ECB3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="113*"/>
                    <ColumnDefinition Width="57*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="lb_memory_curr" Content="Curr. Memory:" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" Width="80" Padding="0,0,0,0" Height="15"/>
                <Label x:Name="lb_memory_curr_memory" Content="MB" HorizontalAlignment="Right" Margin="93,0,5,0" VerticalAlignment="Center" Padding="5,0,5,0" Width="70" Height="15" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
            </Grid>-->
        </Grid>



        <!--GPU Core Clock OC-->
        <Button x:Name="btn_close_application" Content="X" HorizontalAlignment="Right" Margin="0,3,11,0" VerticalAlignment="Top" Click="CloseApplication" Width="18" Height="18" BorderThickness="0,0,0,0" Background="White" FontWeight="Bold"/>
        <Button x:Name="btn_maximize_window" HorizontalAlignment="Right" Margin="0,3,31,0" VerticalAlignment="Top" Width="18" Height="18" BorderThickness="0,0,0,0" Visibility="Hidden">
            <Button.Background>
                <RadialGradientBrush>
                    <GradientStop Color="Black" Offset="0.853"/>
                    <GradientStop Color="White" Offset="0"/>
                </RadialGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="btn_minimize_window" HorizontalAlignment="Right" Margin="0,3,34,0" VerticalAlignment="Top" Click="Minimize_Window" Width="18" Height="18" BorderThickness="0,0,0,0">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.871"/>
                    <GradientStop Color="White" Offset="0.785"/>
                    <GradientStop Color="#FFF1EDED" Offset="0.867"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

        


    </Grid>


</Window>
